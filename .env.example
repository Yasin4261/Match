# --- Spring profile ---
SPRING_PROFILES_ACTIVE=dev

# --- PostgreSQL ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=match
POSTGRES_USER=match
POSTGRES_PASSWORD=match

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379

# --- MinIO ---
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=photos

# --- Mail (Mailhog) ---
MAIL_HOST=mailhog
MAIL_PORT=1025

# --- JWT ---
JWT_SECRET=please-change-this-to-a-32-char-or-longer-secret-string

# --- TURN/coturn ---
TURN_SECRET=turnsecret-change-me
TURN_URLS=turn:coturn:3478?transport=udp,turn:coturn:3478?transport=tcp

